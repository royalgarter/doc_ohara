{
  "name": "doc_ohara",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "ohara": "./bin/ohara.js",
    "capture": "./bin/capture.js",
    "crawl": "./bin/crawl.js"
  },
  "scripts": {
    "help": "node scripts/help.js",
    "dev": "nodemon server.js",
    "build": "echo 'No build step required'",
    "start": "node server.js",
    "lint": "echo 'No lint required'",
    "ohara": "node bin/ohara.js",
    "capture": "node bin/capture.js",
    "crawl": "node bin/crawl.js",
    "ohara:ingest": "node bin/ohara.js ingest \"sample/Mastering Bitcoin 2nd.pdf\"",
    "ohara:query": "node bin/ohara.js query \"bitcoin theoretical\"",
    "ohara:query:expand": "node bin/ohara.js query \"bitcoin theoretical\" --expand-depth 2 --cross-doc-limit 10 --cross-doc-weight 0.5",
    "ohara:ls": "node bin/ohara.js ls",
    "ohara:status": "node bin/ohara.js status",
    "ohara:export": "node bin/ohara.js export --format quartz",
    "ohara:export:json": "node bin/ohara.js export --format json",
    "ohara:verify": "node bin/ohara.js verify",
    "ohara:mcp": "node bin/ohara-mcp.js",
    "build:sumo": "node scripts/build-sumo-index.js",
    "test": "node --test tests/ingest.test.js",
    "admin": "node scripts/admin-queries.js",
    "admin:docs": "node scripts/admin-queries.js docs",
    "admin:sections": "node scripts/admin-queries.js sections",
    "admin:tags": "node scripts/admin-queries.js tags",
    "admin:tag-coverage": "node scripts/admin-queries.js tag-coverage",
    "admin:missing-tags": "node scripts/admin-queries.js missing-tags",
    "admin:repair-stats": "node scripts/admin-queries.js repair-stats",
    "admin:missing-temporal": "node scripts/admin-queries.js missing-temporal",
    "admin:decay-distribution": "node scripts/admin-queries.js decay-distribution"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@llamaindex/liteparse": "^2.1.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "arangojs": "^10.3.1",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "puppeteer-core": "^25.2.1",
    "rdfxml-streaming-parser": "^3.2.0"
  }
}
