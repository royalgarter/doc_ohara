{
  "name": "doc_ohara",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "ohara": "./bin/ohara.js",
    "capture": "./bin/capture.js",
    "crawl": "./bin/crawl.js"
  },
  "scripts": {
    "help": "node --env-file=.env scripts/help.js",
    "dev": "nodemon --exec 'node --env-file=.env' server.js",
    "build": "echo 'No build step required'",
    "start": "node --env-file=.env server.js",
    "lint": "echo 'No lint required'",
    "ohara": "node --env-file=.env bin/ohara.js",
    "capture": "node --env-file=.env bin/capture.js",
    "crawl": "node --env-file=.env bin/crawl.js",
    "ohara:ingest": "node --env-file=.env bin/ohara.js ingest \"sample/Mastering Bitcoin 2nd.pdf\"",
    "ohara:query": "node --env-file=.env bin/ohara.js query \"bitcoin theoretical\"",
    "ohara:query:expand": "node --env-file=.env bin/ohara.js query \"bitcoin theoretical\" --expand-depth 2 --cross-doc-limit 10 --cross-doc-weight 0.5",
    "ohara:ls": "node --env-file=.env bin/ohara.js ls",
    "ohara:status": "node --env-file=.env bin/ohara.js status",
    "ohara:export": "node --env-file=.env bin/ohara.js export --format quartz",
    "ohara:export:json": "node --env-file=.env bin/ohara.js export --format json",
    "ohara:verify": "node --env-file=.env bin/ohara.js verify",
    "ohara:mcp": "node --env-file=.env bin/ohara-mcp.js",
    "build:sumo": "node --env-file=.env scripts/build-sumo-index.js",
    "test": "node --env-file=.env --test tests/ingest.test.js",
    "admin": "node --env-file=.env scripts/admin-queries.js",
    "admin:docs": "node --env-file=.env scripts/admin-queries.js docs",
    "admin:sections": "node --env-file=.env scripts/admin-queries.js sections",
    "admin:tags": "node --env-file=.env scripts/admin-queries.js tags",
    "admin:tag-coverage": "node --env-file=.env scripts/admin-queries.js tag-coverage",
    "admin:missing-tags": "node --env-file=.env scripts/admin-queries.js missing-tags",
    "admin:repair-stats": "node --env-file=.env scripts/admin-queries.js repair-stats",
    "admin:missing-temporal": "node --env-file=.env scripts/admin-queries.js missing-temporal",
    "admin:decay-distribution": "node --env-file=.env scripts/admin-queries.js decay-distribution",
    "enrich:pseudo-queries": "node --env-file=.env scripts/build_pseudo_query_edges.js",
    "enrich:adamic-adar": "node --env-file=.env scripts/build_adamic_adar_edges.js",
    "enrich:knowledge-gaps": "node --env-file=.env scripts/find_knowledge_gaps.js",
    "enrich:clusters": "node --env-file=.env scripts/build_clusters.js",
    "enrich:communities": "node --env-file=.env scripts/build_communities.js",
    "enrich:all": "npm run enrich:pseudo-queries && npm run enrich:adamic-adar && npm run enrich:knowledge-gaps && npm run enrich:communities",
    "eval:generate": "node --env-file=.env scripts/generate_eval_set.js",
    "eval:run": "node --env-file=.env scripts/run_eval.js",
    "eval:ablate": "node --env-file=.env scripts/run_eval.js --ablate",
    "eval:compare": "node scripts/compare_eval_reports.js"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@llamaindex/liteparse": "^2.1.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "arangojs": "^10.3.1",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "express": "^4.21.2",
    "puppeteer-core": "^25.2.1",
    "rdfxml-streaming-parser": "^3.2.0"
  }
}
