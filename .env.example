# ── Similarity / cross-document linking ──────────────────────────────────────
# OHARA_SIMILARITY_THRESHOLD: Minimum Jaccard similarity (0–1) between two
#   documents' entity slug sets to create a SIMILAR_TO edge. Default: 0.1
OHARA_SIMILARITY_THRESHOLD=0.1

# OHARA_ENTITY_PIVOT_LIMIT: Max cross-document paragraphs returned by the
#   entity-pivot phase of retrieval. Default: 5
OHARA_ENTITY_PIVOT_LIMIT=5

# OHARA_ENTITY_PIVOT_WEIGHT: Score multiplier (0–1) applied to entity-pivot
#   results relative to direct keyword-match results. Default: 0.6
OHARA_ENTITY_PIVOT_WEIGHT=0.6

# OHARA_BM25_WEIGHT: Score multiplier for ArangoSearch BM25 full-text results. Default: 1.0
OHARA_BM25_WEIGHT=1.0

# OHARA_SUMO_WEIGHT: Score multiplier for SUMO ontology tag overlap results. Default: 0.4
OHARA_SUMO_WEIGHT=0.4

# OHARA_STRUCT_WEIGHT: Score multiplier for structural graph traversal results. Default: 0.3
OHARA_STRUCT_WEIGHT=0.3

# OHARA_RESULT_LIMIT: Maximum number of fused results to return. Default: 20
OHARA_RESULT_LIMIT=20

# ── Ingest pipeline ───────────────────────────────────────────────────────────
# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
