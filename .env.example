# ── Database ──────────────────────────────────────────────────────────────────
# ARANGO_URL: ArangoDB connection URL (may embed credentials and DB name)
ARANGO_URL=

# ARANGO_USER / ARANGO_PASSWORD: alternative to embedding creds in URL
# ARANGO_USER=
# ARANGO_PASSWORD=

# ── API keys ──────────────────────────────────────────────────────────────────
# Required for Gemini AI API calls (ingest structuring, edge enrichment, query fingerprint).
GEMINI_API_KEY=

# APP_URL: Hosting URL (used for OAuth callbacks and self-referential links).
APP_URL=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Retrieval weights ─────────────────────────────────────────────────────────
OHARA_BM25_WEIGHT=1.0
OHARA_SUMO_WEIGHT=0.4
OHARA_STRUCT_WEIGHT=0.3
OHARA_ENTITY_PIVOT_WEIGHT=0.6
OHARA_CROSS_DOC_WEIGHT=0.4
OHARA_RESULT_LIMIT=20

# ── Cross-document expansion ──────────────────────────────────────────────────
OHARA_CROSS_DOC_LIMIT=5
OHARA_CROSS_DOC_EXPAND_DEPTH=1

# ── Similarity / cross-document linking ──────────────────────────────────────
# Min Jaccard similarity (0–1) between entity sets to create a SIMILAR_TO edge.
OHARA_SIMILARITY_THRESHOLD=0.1

# ── Tier classification (Principal / Integrity / Explorer) ────────────────────
OHARA_PRINCIPAL_SCORE_PCTL=0.75
OHARA_PRINCIPAL_LIMIT=5
OHARA_INTEGRITY_WEIGHT_MIN=0.6
OHARA_INTEGRITY_LLM_VERIFY=false
OHARA_EXPLORER_STOP_WEIGHT=0.15

# ── Ingest pipeline ───────────────────────────────────────────────────────────
OHARA_INGEST_CONCURRENCY=4
OHARA_VIRTUAL_PAGE_SIZE=3000
# OHARA_LLM_CACHE_DIR=        # optional: path to LLM response cache directory
# OHARA_TEST_CHUNKS_LIMIT=0   # dev/test only: limit chunks processed per file (0 = no limit)

# ── Temporal decay ────────────────────────────────────────────────────────────
# Additive score weight from temporal decay (0 = disabled entirely).
OHARA_TEMPORAL_WEIGHT=0.2
# BM25 score above which temporal decay is skipped — protects high-relevance gold articles.
OHARA_TEMPORAL_GATE_FLOOR=0.5
# λ decay rates: temporal_score = exp(−λ · Δdays). Lower λ = slower decay (longer half-life).
OHARA_DECAY_RATE_EVERGREEN=0.000001
OHARA_DECAY_RATE_SCHOLARLY=0.0001
OHARA_DECAY_RATE_CURRENT=0.01
OHARA_DECAY_RATE_EPHEMERAL=0.1
# Min incoming SIMILAR_TO edges to auto-promote a document to EVERGREEN decay class.
OHARA_SIMILAR_TO_EVERGREEN_THRESHOLD=5
# Corrective RAG: filter Phase 3 structural nodes with zero SUMO tag overlap before fusion (true/false).
OHARA_CORRECTIVE_STRUCT=true
# Self-RAG: Gemini responsiveness check on Principal tier results (true/false).
OHARA_SELF_RAG_VERIFY=false
# Conversational RAG: number of prior Q&A turns to prepend to query fingerprint prompt.
OHARA_SESSION_HISTORY_LIMIT=3
# Chain-of-Retrieval: max retrieval iterations chasing Explorer frontier.
OHARA_COR_MAX_ITER=2
# Chain-of-Retrieval: min score improvement between iterations to continue.
OHARA_COR_SCORE_DELTA=0.05
# Reasoning RAG: generate sub-queries from BM25 gaps before Phase 1b (true/false).
OHARA_REASONING_RAG=false
# Reasoning RAG: max sub-queries generated per request.
OHARA_REASONING_SUBQUERY_LIMIT=2
# Speculative RAG: pre-warm Explorer frontier in background after each query (true/false).
OHARA_SPECULATIVE_RAG=false
# Speculative RAG: number of frontier nodes to pre-warm.
OHARA_SPECULATIVE_LIMIT=3
# Entity dedup: auto-run cross-doc entity dedup after each ingest (true/false).
OHARA_AUTO_ENTITY_DEDUP=false
# Agentic RAG: max tool-dispatch iterations per query.
OHARA_AGENT_MAX_ITER=4
# Re-ranker: Gemini cross-encoder pass on Principal tier after classification.
OHARA_RERANK=false
OHARA_RERANK_TOP_N=5
